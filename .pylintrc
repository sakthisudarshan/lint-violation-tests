[MAIN]
jobs=1
ignore=sample_code,generate_metrics_excel.py,coverage_audit.py,debug_counts.py,root_cause_analysis.py,check_test_violations.py,check_main_violations.py,check_json.py
ignore-paths=sample_code

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    too-few-public-methods,
    mixed-line-endings

[FORMAT]
max-line-length=100

[DESIGN]
max-args=5
max-branches=12
max-statements=50
max-nested-blocks=5

[VARIABLES]
init-import=no
