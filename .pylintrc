[MAIN]
jobs=1
ignore=sample_code,tools,scripts,reports
ignore-paths=
    ^sample_code/,
    ^tests/,
    ^tools/,
    ^plugins/,
    ^scripts/,
    ^reports/

[MESSAGES CONTROL]
disable=
    missing-module-docstring,
    too-few-public-methods,
    too-many-public-methods,
    mixed-line-endings,
    duplicate-code,
    line-too-long

[FORMAT]
max-line-length=100

[DESIGN]
max-args=5
max-branches=12
max-statements=50
max-nested-blocks=5

[VARIABLES]
init-import=no
